{
  "name": "@open-event-systems/interview-lib",
  "version": "0.2.0",
  "description": "OES Interview JS library",
  "license": "LGPL-3.0-or-later",
  "author": "Wes <wes@anthronewengland.com>",
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "imports": {
    "#src/*.js": {
      "test": [
        "./src/*.ts",
        "./dist/src/*.js"
      ],
      "default": "./dist/src/*.js"
    }
  },
  "files": [
    "dist/src/**/*",
    "dist/src/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/json-schema": "^7.0.14",
    "@types/psl": "^1.1.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "dayjs": "^1.11.8",
    "email-validator": "^2.0.4",
    "psl": "^1.9.0",
    "wretch": "^2.4.1",
    "zod": "^3.22.4",
    "zod-validation-error": "^2.0.0"
  },
  "peerDependencies": {
    "mobx": "^6.10.2"
  }
}
