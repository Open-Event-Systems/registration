{
  "extends": "../../configs/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "rootDir": "./",
    "outDir": "./dist",
    "paths": {
      "@mantine/core": ["../../node_modules/@mantine/core/lib/index.d.ts"],
      "@mantine/hooks": ["../../node_modules/@mantine/hooks/lib/index.d.ts"],
